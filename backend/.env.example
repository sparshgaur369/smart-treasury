# Supabase PostgreSQL
SUPABASE_DB_URL=jdbc:postgresql://<your-project>.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-password>

# Upstash Redis
UPSTASH_REDIS_URL=rediss://<your-instance>.upstash.io:6379
UPSTASH_REDIS_PASSWORD=<your-password>

# Set to true for Upstash (TLS), false for local Redis
REDIS_SSL_ENABLED=true
